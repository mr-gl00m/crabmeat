{
  "name": "crabmeat",
  "version": "0.1.0",
  "description": "CrabMeat — AI gateway for WebSocket/HTTP message routing to AI providers",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "bin": {
    "crabmeat": "./dist/entry.js"
  },
  "scripts": {
    "dev": "tsx watch src/entry.ts -- run",
    "build": "tsc",
    "start": "node dist/entry.js run",
    "chat": "node dist/entry.js chat",
    "chat:dev": "tsx src/entry.ts chat",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/"
  },
  "dependencies": {
    "arbiter": "file:./vendor/arbiter",
    "@anthropic-ai/sdk": "^0.88.0",
    "@opentelemetry/api": "^1.9.1",
    "@types/sanitize-html": "^2.16.1",
    "adm-zip": "^0.5.17",
    "commander": "^13.1.0",
    "imapflow": "^1.3.1",
    "ink": "^5.2.1",
    "mailparser": "^3.9.8",
    "marked": "^18.0.0",
    "nodemailer": "^8.0.5",
    "openai": "^6.34.0",
    "pdfjs-dist": "^5.6.205",
    "pino": "^9.6.0",
    "playwright": "^1.59.1",
    "react": "^18.3.1",
    "sanitize-html": "^2.17.2",
    "ws": "^8.18.0",
    "zod": "^3.24.0"
  },
  "optionalDependencies": {
    "@opentelemetry/exporter-metrics-otlp-proto": "^0.215.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.215.0",
    "@opentelemetry/resources": "^2.7.0",
    "@opentelemetry/sdk-metrics": "^2.7.0",
    "@opentelemetry/sdk-node": "^0.215.0",
    "@opentelemetry/sdk-trace-base": "^2.7.0",
    "@opentelemetry/semantic-conventions": "^1.40.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^22.12.0",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^18.3.28",
    "@types/ws": "^8.5.14",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "packageManager": "npm@10.9.7"
}
